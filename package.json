{
  "name": "orbis",
  "version": "0.1.0",
  "private": true,
  "description": "Orbis — restaurant courier tracking system (monorepo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "web": "npm run dev --workspace=@orbis/web",
    "mobile": "npm run start --workspace=@orbis/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "patch-package": "^8.0.0"
  },
  "overrides": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
